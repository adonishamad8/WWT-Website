/vendor/
/node_modules/
/storage/*.key
/storage/app/*
/storage/framework/*
/storage/logs/*
!.gitignore
/public/storage
.env
.env.*.backup
.phpunit.result.cache
composer.lock
npm-debug.log*
yarn-error.log*
.DS_Store
.idea/
.vscode/

# Laravel app inside /core
/core/vendor/
/core/node_modules/
/core/storage/*.key
/core/storage/app/*
/core/storage/framework/*
/core/storage/logs/*
!/core/storage/.gitignore
/core/.env
/core/.env.*.backup

# Misc
error_log
*.zip
*.tar
*.tar.gz
.env
/vendor/
/node_modules/
/storage/framework/
/storage/logs/
public/uploads/
public/storage/

# Ignore all SQL dumps except our backups folder
*.sql
!database/backups/*.sql
